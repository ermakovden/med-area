# Version control
.git
.gitignore
.gitattributes

# Docker files (don't copy into image)
docker-compose*.yaml
docker-compose*.yml
compose*.yml
compose*.yaml
.dockerignore
Dockerfile*

# PHP dependencies (installed in image)
vendor/

# Node dependencies and build artifacts
node_modules/
html/

# Laravel storage (mounted as volume in dev)
storage/logs/*
storage/framework/cache/*
storage/framework/sessions/*
storage/framework/views/*
bootstrap/cache/*

# Test files
tests/
phpunit.xml
.phpunit.cache/

# Code quality tools
phpstan.neon
.php-cs-fixer.cache

# CI/CD
.github/

# AI / editor context
.ai-factory/
.claude/
.agents/
.qwen/
.mcp.json
.ai-factory.json
AGENTS.md

# Documentation
docs/
*.md
openapi.yaml

# Environment files (NEVER bake into image)
.env
.env.*
!.env.example

# IDE
.idea/
.vscode/
*.DS_Store

# Logs
*.log
